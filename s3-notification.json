{
  "LambdaFunctionConfigurations": [
    {
      "Id": "trigger-process-dataset",
      "LambdaFunctionArn": "arn:aws:lambda:us-east-1:000000000000:function:process-dataset",
      "Events": ["s3:ObjectCreated:*"],
      "Filter": {
        "Key": {
          "FilterRules": [
            { "Name": "prefix", "Value": "raw/" },
            { "Name": "suffix", "Value": ".csv" }
          ]
        }
      }
    }
  ]
}